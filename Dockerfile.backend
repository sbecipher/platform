FROM python:3.11-slim

WORKDIR /app

# Copy the pyproject.toml and the package code
COPY pyproject.toml .
COPY scp_core /app/scp_core

# Install the package
RUN pip install --no-cache-dir .

# Set PYTHONPATH so scp_core is discoverable as a package
ENV PYTHONPATH=/app

EXPOSE 8000

# Run Uvicorn pointing to our main.py
CMD ["uvicorn", "scp_core.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
