FROM python:3.11-slim

WORKDIR /app

# Copy the requirements and install
COPY scp_core/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the backend code
COPY scp_core /app/scp_core

# Set PYTHONPATH so scp_core is discoverable as a package
ENV PYTHONPATH=/app

EXPOSE 8000

# Run Uvicorn pointing to our main.py
CMD ["uvicorn", "scp_core.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
